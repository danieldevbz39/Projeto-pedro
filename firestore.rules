// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: leads
// Document ID: auto-generated
// Fields:
//   - name: string (required) - Full name
//   - whatsapp: string (required) - Phone/WhatsApp
//   - goal: string (required) - Main objective
//   - createdAt: timestamp (required) - Creation time
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "danielvendas25@gmail.com" && request.auth.token.email_verified == true);
    }

    function isValidLead(data) {
      return data.keys().hasAll(['name', 'whatsapp', 'goal', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.whatsapp is string && data.whatsapp.size() > 5 && data.whatsapp.size() < 25 &&
             data.goal is string && data.goal.size() > 0 && data.goal.size() < 50;
    }

    match /leads/{leadId} {
      // Anyone can submit a lead
      allow create: if isValidLead(request.resource.data);
      
      // Only admin can read or manage leads
      allow read, update, delete: if isAdmin();
    }
  }
}
