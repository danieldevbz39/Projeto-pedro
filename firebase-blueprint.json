{
  "entities": {
    "leads": {
      "title": "Leads",
      "description": "Potential students who signed up via the landing page.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full name of the lead."
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "Email address of the lead."
        },
        "whatsapp": {
          "type": "string",
          "description": "WhatsApp number of the lead."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the lead was created."
        }
      },
      "required": ["name", "email", "whatsapp", "createdAt"]
    }
  },
  "firestore": {
    "/leads/{leadId}": {
      "schema": "leads",
      "description": "Collection of leads captured from the landing page."
    }
  }
}
